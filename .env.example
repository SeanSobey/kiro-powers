COMPOSE_PROJECT_NAME=kiro-powers
# ─── Staging ─────────────────────────────────────────────────────────────────
# Host directory shared with chart, markitdown, pandoc, and pdf-reader containers.
# The AI reads this value at runtime to know where to copy files.
STAGING_DIR=${USERPROFILE}/mcp-staging

# ─── API Keys ────────────────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=<your_github_pat_here>
NOTION_API_KEY=<your_notion_api_key_here>
YOUTUBE_API_KEY=<your_youtube_api_key_here>
CONTEXT7_API_KEY=<your_context7_api_key_here>
