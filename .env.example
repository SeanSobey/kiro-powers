# ─── Staging ─────────────────────────────────────────────────────────────────
# Host directory shared with chart, markitdown, and pdf-reader containers.
# The AI reads this value at runtime to know where to copy files.
# Must be an absolute path — no environment variable expansion.
STAGING_DIR=

# ─── API Keys ────────────────────────────────────────────────────────────────
NOTION_API_KEY=<your_notion_api_key_here>
YOUTUBE_API_KEY=<your_youtube_api_key_here>
CONTEXT7_API_KEY=<your_context7_api_key_here>
